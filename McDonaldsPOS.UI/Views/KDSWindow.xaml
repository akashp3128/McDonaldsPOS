<Window x:Class="McDonaldsPOS.UI.Views.KDSWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:McDonaldsPOS.UI.ViewModels"
        mc:Ignorable="d"
        Title="Kitchen Display System (KDS)"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        Background="{StaticResource DarkBackground}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        d:DataContext="{d:DesignInstance Type=vm:KDSViewModel}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ChefHat"
                                            Width="36" Height="36"
                                            Foreground="{StaticResource McDonaldsYellow}"
                                            VerticalAlignment="Center"/>
                    <TextBlock Text="Kitchen Display System"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Status Counts -->
                    <Border Background="#FFC107" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" Pending" FontSize="14" Foreground="Black" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2196F3" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding InPrepCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" In Prep" FontSize="14" Foreground="White" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#4CAF50" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ReadyCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" Ready" FontSize="14" Foreground="White" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource MaterialDesignIconButton}"
                           Width="48" Height="48"
                           Margin="16,0,0,0"
                           Command="{Binding RefreshOrdersCommand}"
                           ToolTip="Refresh">
                        <materialDesign:PackIcon Kind="Refresh" Width="28" Height="28"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Order Columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pending Orders -->
            <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="12" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFC107" Padding="16">
                        <TextBlock Text="PENDING" FontSize="20" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding PendingOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Order Header -->
                                            <Grid Grid.Row="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource McDonaldsYellow}" CornerRadius="8" Padding="12,4">
                                                        <TextBlock Text="{Binding OrderNumber, StringFormat=#\{0\}}"
                                                                  FontSize="24" FontWeight="Bold" Foreground="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding OrderTime}"
                                                              FontSize="14" Foreground="Gray"
                                                              VerticalAlignment="Center"
                                                              Margin="12,0,0,0"/>
                                                </StackPanel>
                                                <Border Background="{Binding IsOverdue, Converter={StaticResource BoolToSelectionBrush}}"
                                                       CornerRadius="4" Padding="8,4"
                                                       HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ElapsedDisplay}"
                                                              FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                                <Border Background="{StaticResource McDonaldsYellow}"
                                                                       CornerRadius="4" Padding="4,2"
                                                                       Margin="8,0,0,0"
                                                                       Visibility="{Binding IsCombo, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="MEAL" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Modifiers}"
                                                                      FontSize="12" Foreground="#FFA726"
                                                                      Margin="36,2,0,0"
                                                                      Visibility="{Binding HasModifiers, Converter={StaticResource BoolToVisibility}}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Bump Button -->
                                            <Button Grid.Row="2"
                                                   Style="{StaticResource ActionButtonSecondary}"
                                                   Content="START"
                                                   Height="50"
                                                   Command="{Binding DataContext.StartOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- In Prep Orders -->
            <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="12" Margin="8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2196F3" Padding="16">
                        <TextBlock Text="IN PREP" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding InPrepOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16"
                                           BorderBrush="#2196F3" BorderThickness="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Order Header -->
                                            <Grid Grid.Row="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#2196F3" CornerRadius="8" Padding="12,4">
                                                        <TextBlock Text="{Binding OrderNumber, StringFormat=#\{0\}}"
                                                                  FontSize="24" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding OrderTime}"
                                                              FontSize="14" Foreground="Gray"
                                                              VerticalAlignment="Center"
                                                              Margin="12,0,0,0"/>
                                                </StackPanel>
                                                <Border Background="{Binding IsOverdue, Converter={StaticResource BoolToSelectionBrush}}"
                                                       CornerRadius="4" Padding="8,4"
                                                       HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ElapsedDisplay}"
                                                              FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Modifiers}"
                                                                      FontSize="12" Foreground="#FFA726"
                                                                      Margin="36,2,0,0"
                                                                      Visibility="{Binding HasModifiers, Converter={StaticResource BoolToVisibility}}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Bump Button -->
                                            <Button Grid.Row="2"
                                                   Style="{StaticResource ActionButtonPrimary}"
                                                   Background="#4CAF50"
                                                   Content="READY"
                                                   Height="50"
                                                   Command="{Binding DataContext.BumpOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Ready Orders -->
            <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="12" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#4CAF50" Padding="16">
                        <TextBlock Text="READY" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding ReadyOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16"
                                           BorderBrush="#4CAF50" BorderThickness="3">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Order Header -->
                                            <Grid Grid.Row="0">
                                                <Border Background="#4CAF50" CornerRadius="8" Padding="16,8">
                                                    <TextBlock Text="{Binding OrderNumber, StringFormat=#\{0\}}"
                                                              FontSize="32" FontWeight="Bold" Foreground="White"
                                                              HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Complete Button -->
                                            <Button Grid.Row="2"
                                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                                   Content="COMPLETE"
                                                   Foreground="#4CAF50"
                                                   BorderBrush="#4CAF50"
                                                   Height="50"
                                                   Command="{Binding DataContext.CompleteOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

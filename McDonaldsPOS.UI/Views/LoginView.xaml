<UserControl x:Class="McDonaldsPOS.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:McDonaldsPOS.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
             Background="{StaticResource DarkBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Login Card -->
        <materialDesign:Card Grid.Column="1"
                            Background="{StaticResource CardBackground}"
                            Padding="48"
                            UniformCornerRadius="16"
                            VerticalAlignment="Center">
            <StackPanel Width="400">
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <materialDesign:PackIcon Kind="FoodForkDrink"
                                            Width="80" Height="80"
                                            Foreground="{StaticResource McDonaldsYellow}"
                                            HorizontalAlignment="Center"/>
                    <TextBlock Text="McDonald's POS"
                              FontSize="28" FontWeight="Bold"
                              Foreground="{StaticResource McDonaldsYellow}"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,0"/>
                    <TextBlock Text="Crew Sign In"
                              FontSize="16"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0"/>
                </StackPanel>

                <!-- User Selection -->
                <TextBlock Text="Select User" FontSize="14" Foreground="Gray" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding Users}"
                        SelectedItem="{Binding SelectedUser}"
                        Background="Transparent"
                        BorderThickness="0"
                        MaxHeight="200"
                        Margin="0,0,0,24">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackgroundHover}"
                                   CornerRadius="8"
                                   Padding="16,12"
                                   Margin="2">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Account"
                                                            Width="24" Height="24"
                                                            Foreground="{StaticResource McDonaldsYellow}"
                                                            VerticalAlignment="Center"/>
                                    <StackPanel Margin="12,0,0,0">
                                        <TextBlock Text="{Binding DisplayName}"
                                                  FontSize="16" FontWeight="SemiBold"
                                                  Foreground="White"/>
                                        <TextBlock Text="{Binding Role}"
                                                  FontSize="12" Foreground="Gray"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- PIN Display -->
                <Border Background="#1A1A1A"
                       CornerRadius="8"
                       Height="60"
                       Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="Enter 4-digit PIN"
                                  FontSize="20"
                                  Foreground="Gray"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding Pin, Converter={StaticResource StringNotEmpty}, ConverterParameter=Inverse}"/>
                        <TextBlock Text="{Binding Pin, Converter={StaticResource PinToMask}}"
                                  FontSize="36"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- PIN Pad -->
                <UniformGrid Columns="3" Rows="4" HorizontalAlignment="Center">
                    <Button Content="1" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="1"/>
                    <Button Content="2" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="2"/>
                    <Button Content="3" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="3"/>
                    <Button Content="4" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="4"/>
                    <Button Content="5" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="5"/>
                    <Button Content="6" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="6"/>
                    <Button Content="7" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="7"/>
                    <Button Content="8" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="8"/>
                    <Button Content="9" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="9"/>
                    <Button Style="{StaticResource PinPadButton}" Command="{Binding ClearPinCommand}" Background="{StaticResource McDonaldsRed}">
                        <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                    </Button>
                    <Button Content="0" Style="{StaticResource PinPadButton}" Command="{Binding AppendPinCommand}" CommandParameter="0"/>
                    <Button Style="{StaticResource PinPadButton}" Command="{Binding BackspacePinCommand}">
                        <materialDesign:PackIcon Kind="BackspaceOutline" Width="24" Height="24"/>
                    </Button>
                </UniformGrid>

                <!-- Status Message -->
                <Border Background="{Binding IsStatusError, Converter={StaticResource BoolToStatusBrush}}"
                       CornerRadius="8"
                       Padding="16"
                       Margin="0,24,0,0"
                       Opacity="0.9">
                    <TextBlock Text="{Binding StatusMessage}"
                              FontSize="14"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"/>
                </Border>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,16,0,0"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>

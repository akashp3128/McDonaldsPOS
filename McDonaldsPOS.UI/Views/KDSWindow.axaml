<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:McDonaldsPOS.UI.ViewModels"
        xmlns:converters="clr-namespace:McDonaldsPOS.UI.Converters"
        mc:Ignorable="d"
        x:Class="McDonaldsPOS.UI.Views.KDSWindow"
        x:DataType="vm:KDSViewModel"
        Title="Kitchen Display System (KDS)"
        Width="1400" Height="800"
        MinWidth="1000" MinHeight="600"
        Background="#1E1E1E">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrush"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="12" Padding="24" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="👨‍🍳"
                              FontSize="36"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Kitchen Display System"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status Counts -->
                    <Border Background="#FFC107" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" Pending" FontSize="14" Foreground="Black" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2196F3" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding InPrepCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" In Prep" FontSize="14" Foreground="White" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#4CAF50" CornerRadius="8" Padding="16,8" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ReadyCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" Ready" FontSize="14" Foreground="White" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>

                    <Button Width="48" Height="48"
                           Margin="16,0,0,0"
                           Command="{Binding RefreshOrdersCommand}"
                           Background="#3D3D3D"
                           CornerRadius="24"
                           ToolTip.Tip="Refresh">
                        <TextBlock Text="🔄" FontSize="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Order Columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pending Orders -->
            <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="12" Margin="0,0,8,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#FFC107" Padding="16" CornerRadius="12,12,0,0">
                        <TextBlock Text="PENDING" FontSize="20" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding PendingOrders}" x:Name="PendingOrdersControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <!-- Order Header -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Border Background="#FFC72C" CornerRadius="8" Padding="12,4">
                                                        <TextBlock Text="{Binding OrderNumber, StringFormat='#{0}'}"
                                                                  FontSize="24" FontWeight="Bold" Foreground="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding OrderTime}"
                                                              FontSize="14" Foreground="Gray"
                                                              VerticalAlignment="Center"
                                                              Margin="12,0,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                       Background="{Binding IsOverdue, Converter={StaticResource BoolToSelectionBrush}}"
                                                       CornerRadius="4" Padding="8,4">
                                                    <TextBlock Text="{Binding ElapsedDisplay}"
                                                              FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                                <Border Background="#FFC72C"
                                                                       CornerRadius="4" Padding="4,2"
                                                                       Margin="8,0,0,0"
                                                                       IsVisible="{Binding IsCombo}">
                                                                    <TextBlock Text="MEAL" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Modifiers}"
                                                                      FontSize="12" Foreground="#FFA726"
                                                                      Margin="36,2,0,0"
                                                                      IsVisible="{Binding HasModifiers}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Start Button -->
                                            <Button Grid.Row="2"
                                                   Classes="kds-action"
                                                   Background="#FFC107"
                                                   Content="START"
                                                   Height="50"
                                                   Command="{Binding #PendingOrdersControl.((vm:KDSViewModel)DataContext).StartOrderCommand}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- In Prep Orders -->
            <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="12" Margin="8,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#2196F3" Padding="16" CornerRadius="12,12,0,0">
                        <TextBlock Text="IN PREP" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding InPrepOrders}" x:Name="InPrepOrdersControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16"
                                           BorderBrush="#2196F3" BorderThickness="2">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <!-- Order Header -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Border Background="#2196F3" CornerRadius="8" Padding="12,4">
                                                        <TextBlock Text="{Binding OrderNumber, StringFormat='#{0}'}"
                                                                  FontSize="24" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding OrderTime}"
                                                              FontSize="14" Foreground="Gray"
                                                              VerticalAlignment="Center"
                                                              Margin="12,0,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                       Background="{Binding IsOverdue, Converter={StaticResource BoolToSelectionBrush}}"
                                                       CornerRadius="4" Padding="8,4">
                                                    <TextBlock Text="{Binding ElapsedDisplay}"
                                                              FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Modifiers}"
                                                                      FontSize="12" Foreground="#FFA726"
                                                                      Margin="36,2,0,0"
                                                                      IsVisible="{Binding HasModifiers}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Ready Button -->
                                            <Button Grid.Row="2"
                                                   Classes="kds-action"
                                                   Background="#4CAF50"
                                                   Content="READY"
                                                   Height="50"
                                                   Command="{Binding #InPrepOrdersControl.((vm:KDSViewModel)DataContext).BumpOrderCommand}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Ready Orders -->
            <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="12" Margin="8,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#4CAF50" Padding="16" CornerRadius="12,12,0,0">
                        <TextBlock Text="READY" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding ReadyOrders}" x:Name="ReadyOrdersControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D3D3D" CornerRadius="12" Margin="4" Padding="16"
                                           BorderBrush="#4CAF50" BorderThickness="3">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <!-- Order Header -->
                                            <Border Grid.Row="0" Background="#4CAF50" CornerRadius="8" Padding="16,8" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding OrderNumber, StringFormat='#{0}'}"
                                                          FontSize="32" FontWeight="Bold" Foreground="White"
                                                          HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Order Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#555555" CornerRadius="4" Padding="6,2" MinWidth="28">
                                                                    <TextBlock Text="{Binding Quantity}"
                                                                              FontWeight="Bold" Foreground="White"
                                                                              HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}"
                                                                          FontSize="16" Foreground="White"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Complete Button -->
                                            <Button Grid.Row="2"
                                                   Classes="kds-action-outline"
                                                   Content="COMPLETE"
                                                   Foreground="#4CAF50"
                                                   BorderBrush="#4CAF50"
                                                   Height="50"
                                                   Command="{Binding #ReadyOrdersControl.((vm:KDSViewModel)DataContext).CompleteOrderCommand}"
                                                   CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.kds-action">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.kds-action-outline">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Window.Styles>
</Window>

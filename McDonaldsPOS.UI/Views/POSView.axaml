<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:McDonaldsPOS.UI.ViewModels"
             xmlns:converters="clr-namespace:McDonaldsPOS.UI.Converters"
             mc:Ignorable="d"
             x:Class="McDonaldsPOS.UI.Views.POSView"
             x:DataType="vm:POSViewModel"
             Background="#1E1E1E">

    <UserControl.Resources>
        <converters:HexColorToBrushConverter x:Key="HexToBrush"/>
        <converters:CurrencyConverter x:Key="Currency"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibility"/>
        <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrush"/>
        <converters:PinToMaskConverter x:Key="PinToMask"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="*,380">
        <!-- Left Panel: Categories + Menu Items -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="8">
            <!-- Category Buttons -->
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="category"
                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).SelectCategoryCommand}"
                                   CommandParameter="{Binding}"
                                   Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                <TextBlock Text="{Binding Name}"
                                          TextWrapping="Wrap"
                                          TextAlignment="Center"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Menu Items Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="menu-item"
                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).SelectMenuItemCommand}"
                                   CommandParameter="{Binding}"
                                   Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                              TextWrapping="Wrap"
                                              TextAlignment="Center"
                                              FontWeight="SemiBold"
                                              FontSize="13"/>
                                    <TextBlock Text="{Binding Price}"
                                              TextAlignment="Center"
                                              FontSize="14"
                                              FontWeight="Bold"
                                              Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border Grid.Row="1"
                   Background="#80000000"
                   IsVisible="{Binding IsLoading}">
                <ProgressBar IsIndeterminate="True" Width="200" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Right Panel: Order -->
        <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="12,0,0,12" Margin="0,8,8,8">
            <Grid RowDefinitions="Auto,*,Auto,Auto">
                <!-- Order Header -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="16" CornerRadius="12,0,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Current Order"
                                      FontSize="18" FontWeight="Bold"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                        </StackPanel>
                        <Border Background="#DA291C"
                               CornerRadius="12"
                               Padding="12,4"
                               HorizontalAlignment="Right"
                               IsVisible="{Binding ItemCount, Converter={StaticResource CountToVisibility}}">
                            <TextBlock Text="{Binding ItemCount, StringFormat={}{0} items}"
                                      FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Order Items List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <ItemsControl ItemsSource="{Binding OrderItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="order-item">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <!-- Item Name & Combo Badge -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}"
                                                      FontSize="15" FontWeight="SemiBold"
                                                      Foreground="White"/>
                                            <Border Background="#FFC72C"
                                                   CornerRadius="4"
                                                   Padding="6,2"
                                                   Margin="8,0,0,0"
                                                   IsVisible="{Binding IsCombo}">
                                                <TextBlock Text="MEAL" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Price -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                  Text="{Binding Price}"
                                                  FontSize="15" FontWeight="Bold"
                                                  Foreground="#FFC72C"/>

                                        <!-- Modifiers -->
                                        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                                  Text="{Binding Modifiers}"
                                                  FontSize="12"
                                                  Foreground="#FFA726"
                                                  IsVisible="{Binding HasModifiers}"
                                                  Margin="0,4,0,0"/>

                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                                                   Orientation="Horizontal"
                                                   Margin="0,8,0,0">
                                            <!-- Quantity Controls -->
                                            <Button Width="36" Height="36" Padding="0"
                                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).DecreaseQuantityCommand}"
                                                   CommandParameter="{Binding}">
                                                <TextBlock Text="−" FontSize="20"/>
                                            </Button>
                                            <Border Background="#404040" CornerRadius="4" Padding="12,4" Margin="4,0">
                                                <TextBlock Text="{Binding Quantity}"
                                                          FontSize="16" FontWeight="Bold"
                                                          Foreground="White"/>
                                            </Border>
                                            <Button Width="36" Height="36" Padding="0"
                                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).IncreaseQuantityCommand}"
                                                   CommandParameter="{Binding}">
                                                <TextBlock Text="+" FontSize="20"/>
                                            </Button>

                                            <!-- Modifiers Button -->
                                            <Button Width="36" Height="36" Margin="8,0,0,0" Padding="0"
                                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).OpenModifiersCommand}"
                                                   CommandParameter="{Binding}"
                                                   IsVisible="{Binding CanModify}"
                                                   ToolTip.Tip="Modifiers">
                                                <TextBlock Text="⚙" FontSize="16"/>
                                            </Button>

                                            <!-- Remove Button -->
                                            <Button Width="36" Height="36" Padding="0"
                                                   Foreground="Gray"
                                                   Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).RemoveOrderItemCommand}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip.Tip="Remove">
                                                <TextBlock Text="✕" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty Order Message -->
                <StackPanel Grid.Row="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding !ItemCount, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}">
                    <TextBlock Text="🛒" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="No items in order"
                              FontSize="16"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="Select items from the menu"
                              FontSize="12"
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Order Totals -->
                <Border Grid.Row="2" Background="#1A1A1A" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <TextBlock Text="Subtotal" FontSize="14" Foreground="Gray"/>
                            <TextBlock Text="{Binding Subtotal, Converter={StaticResource Currency}}"
                                      FontSize="14" Foreground="White"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Tax (8%)" FontSize="14" Foreground="Gray"/>
                            <TextBlock Text="{Binding Tax, Converter={StaticResource Currency}}"
                                      FontSize="14" Foreground="White"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Margin="0,8" Background="#404040"/>
                        <Grid>
                            <TextBlock Text="TOTAL" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Total, Converter={StaticResource Currency}}"
                                      FontSize="24" FontWeight="Bold"
                                      Foreground="#FFC72C"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Margin="8">
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0"
                               Classes="action-secondary"
                               Content="SEND TO KITCHEN"
                               Command="{Binding SendToKitchenCommand}"/>
                        <Button Grid.Column="1"
                               Classes="action-primary"
                               Content="PAY NOW"
                               Command="{Binding OpenPaymentCommand}"/>
                    </Grid>
                    <Button Content="CLEAR ORDER"
                           Background="Transparent"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           BorderThickness="1"
                           Height="40"
                           CornerRadius="8"
                           Margin="4,8,4,4"
                           Command="{Binding ClearOrderCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DIALOGS ========== -->

        <!-- Size Selection Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               IsVisible="{Binding ShowSizeDialog}">
            <Border Background="#2D2D2D"
                   CornerRadius="16"
                   Padding="32"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="400">
                <StackPanel>
                    <TextBlock Text="Select Size"
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>

                    <Button Classes="touch-large" Background="#4CAF50" Foreground="White"
                           Content="SMALL" HorizontalAlignment="Stretch"
                           Command="{Binding SelectSizeCommand}" CommandParameter="Small"/>
                    <Button Classes="touch-large" Background="#FFC72C" Foreground="Black"
                           Content="MEDIUM" HorizontalAlignment="Stretch"
                           Command="{Binding SelectSizeCommand}" CommandParameter="Medium"/>
                    <Button Classes="touch-large" Background="#DA291C" Foreground="White"
                           Content="LARGE" HorizontalAlignment="Stretch"
                           Command="{Binding SelectSizeCommand}" CommandParameter="Large"/>

                    <Button Content="CANCEL"
                           Background="Transparent" Foreground="Gray"
                           BorderBrush="Gray" BorderThickness="1"
                           Height="48" CornerRadius="8"
                           Margin="0,16,0,0"
                           Command="{Binding CancelSizeDialogCommand}"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Combo Prompt Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               IsVisible="{Binding ShowComboPrompt}">
            <Border Background="#2D2D2D"
                   CornerRadius="16"
                   Padding="32"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="450">
                <StackPanel>
                    <TextBlock Text="🍟🥤" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Make it a Meal?"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,8"/>
                    <TextBlock Text="Add Medium Fries + Medium Drink"
                              FontSize="16"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>

                    <Button Classes="action-secondary"
                           Height="70" FontSize="20"
                           Content="✓ YES, MAKE IT A MEAL"
                           Command="{Binding MakeItAMealCommand}"/>

                    <Button Content="NO THANKS"
                           Background="Transparent" Foreground="Gray"
                           BorderBrush="Gray" BorderThickness="1"
                           Height="50" CornerRadius="8"
                           Margin="0,12,0,0"
                           Command="{Binding NoMealCommand}"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Modifiers Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               IsVisible="{Binding ShowModifierDialog}">
            <Border Background="#2D2D2D"
                   CornerRadius="16"
                   Padding="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="500"
                   MaxHeight="600">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Customize Item"
                                  FontSize="24" FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ModifierTargetItem.DisplayName}"
                                  FontSize="16"
                                  Foreground="#FFC72C"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,16"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableModifiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="4" Height="56"
                                           HorizontalContentAlignment="Stretch"
                                           Background="{Binding IsSelected, Converter={StaticResource BoolToSelectionBrush}}"
                                           Command="{Binding $parent[UserControl].((vm:POSViewModel)DataContext).ToggleModifierCommand}"
                                           CommandParameter="{Binding}">
                                        <Grid Margin="8,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="✓" FontSize="18" Foreground="White"
                                                          IsVisible="{Binding IsSelected}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}"
                                                          FontSize="16" Foreground="White"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PriceDisplay}"
                                                      FontSize="14" FontWeight="Bold"
                                                      Foreground="#FFC72C"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                           Classes="action-primary"
                           Content="DONE"
                           Margin="0,16,0,0"
                           Command="{Binding CloseModifiersCommand}"/>
                </Grid>
            </Border>
        </Border>

        <!-- Payment Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               IsVisible="{Binding ShowPaymentDialog}">
            <Border Background="#2D2D2D"
                   CornerRadius="16"
                   Padding="32"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="500">
                <StackPanel>
                    <TextBlock Text="Payment"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>

                    <!-- Total Display -->
                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="0,16">
                        <StackPanel>
                            <TextBlock Text="Total Due" FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Total, Converter={StaticResource Currency}}"
                                      FontSize="48" FontWeight="Bold"
                                      Foreground="#FFC72C"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Payment Methods -->
                    <Grid ColumnDefinitions="*,*" Margin="0,8">
                        <Button Grid.Column="0"
                               Classes="action-secondary"
                               Height="80"
                               Command="{Binding PayCardCommand}">
                            <StackPanel>
                                <TextBlock Text="💳" FontSize="28"/>
                                <TextBlock Text="CARD" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <Border Grid.Column="1" Background="#404040" CornerRadius="8" Margin="4" Padding="8">
                            <StackPanel>
                                <TextBlock Text="CASH" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <!-- Amount Display -->
                                <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TenderedAmount, StringFormat=${0}}"
                                              FontSize="20" FontWeight="Bold"
                                              Foreground="White"
                                              HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Quick Amount Buttons -->
                                <UniformGrid Columns="2" Rows="2">
                                    <Button Content="$10" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="10"/>
                                    <Button Content="$20" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="20"/>
                                    <Button Content="$50" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="50"/>
                                    <Button Content="$100" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="100"/>
                                </UniformGrid>

                                <!-- Change Display -->
                                <Border Background="#4CAF50" CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                       IsVisible="{Binding ChangeAmount, Converter={StaticResource CountToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="Change" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ChangeAmount, Converter={StaticResource Currency}}"
                                                  FontSize="18" FontWeight="Bold"
                                                  Foreground="White"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button Classes="action-primary"
                                       Content="PAY CASH"
                                       Height="44"
                                       Margin="0,8,0,0"
                                       Command="{Binding PayCashCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Button Content="CANCEL"
                           Background="Transparent" Foreground="Gray"
                           BorderBrush="Gray" BorderThickness="1"
                           Height="44" CornerRadius="8"
                           Margin="0,16,0,0"
                           Command="{Binding CancelPaymentCommand}"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Receipt Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               IsVisible="{Binding ShowReceiptDialog}">
            <Border Background="White"
                   CornerRadius="8"
                   Padding="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="350">
                <StackPanel>
                    <!-- Receipt Header -->
                    <TextBlock Text="McDonald's"
                              FontSize="28" FontWeight="Bold"
                              Foreground="Black"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Thank You For Your Order!"
                              FontSize="14"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,4,0,16"/>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <!-- Order Number -->
                    <Border Background="#FFC72C" CornerRadius="8" Padding="16" Margin="0,8">
                        <StackPanel>
                            <TextBlock Text="ORDER NUMBER"
                                      FontSize="12" FontWeight="Bold"
                                      Foreground="Black"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CompletedOrder.OrderNumber}"
                                      FontSize="48" FontWeight="Bold"
                                      Foreground="Black"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="LightGray" Margin="0,16,0,8"/>

                    <!-- Order Items -->
                    <ItemsControl ItemsSource="{Binding CompletedOrder.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="Black"/>
                                        <TextBlock Text="x" Margin="4,0" Foreground="Gray"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="Black"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding LineTotal, StringFormat=${0:F2}}"
                                              HorizontalAlignment="Right"
                                              Foreground="Black"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <!-- Totals -->
                    <Grid Margin="0,4">
                        <TextBlock Text="Subtotal" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.Subtotal, StringFormat=${0:F2}}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tax" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.TaxAmount, StringFormat=${0:F2}}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>
                    <Grid Margin="0,8">
                        <TextBlock Text="TOTAL" FontWeight="Bold" FontSize="18" Foreground="Black"/>
                        <TextBlock Text="{Binding CompletedOrder.Total, StringFormat=${0:F2}}"
                                  FontWeight="Bold" FontSize="18"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <TextBlock Text="{Binding CompletedOrder.PaidAt, StringFormat={}{0:MM/dd/yyyy h:mm tt}}"
                              FontSize="12"
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>

                    <Button Classes="action-secondary"
                           Content="NEW ORDER"
                           Margin="0,16,0,0"
                           Command="{Binding CloseReceiptCommand}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="McDonaldsPOS.UI.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:McDonaldsPOS.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             d:DataContext="{d:DesignInstance Type=vm:POSViewModel}"
             Background="{StaticResource DarkBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="500"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Categories + Menu Items -->
        <Grid Grid.Column="0" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Category Buttons -->
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource CategoryButton}"
                                   Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"
                                   Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                <Button.Content>
                                    <TextBlock Text="{Binding Name}"
                                              TextWrapping="Wrap"
                                              TextAlignment="Center"/>
                                </Button.Content>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Menu Items Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MenuItemCard}"
                                   Command="{Binding DataContext.SelectMenuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"
                                   Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                              TextWrapping="Wrap"
                                              TextAlignment="Center"
                                              FontWeight="SemiBold"
                                              FontSize="13"/>
                                    <TextBlock Text="{Binding Price}"
                                              TextAlignment="Center"
                                              FontSize="14"
                                              FontWeight="Bold"
                                              Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border Grid.Row="1"
                   Background="#80000000"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar IsIndeterminate="True" Width="200"/>
            </Border>
        </Grid>

        <!-- Right Panel: Order -->
        <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="12,0,0,12" Margin="0,8,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Order Header -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="16">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cart" Width="24" Height="24"
                                                    Foreground="{StaticResource McDonaldsYellow}"
                                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Current Order"
                                      FontSize="18" FontWeight="Bold"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="{StaticResource McDonaldsRed}"
                                   CornerRadius="12"
                                   Padding="12,4"
                                   Visibility="{Binding ItemCount, Converter={StaticResource CountToVisibility}}">
                                <TextBlock Text="{Binding ItemCount, StringFormat={}{0} items}"
                                          FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Order Items List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <ItemsControl ItemsSource="{Binding OrderItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource OrderItemCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Item Name & Combo Badge -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}"
                                                      FontSize="15" FontWeight="SemiBold"
                                                      Foreground="White"/>
                                            <Border Background="{StaticResource McDonaldsYellow}"
                                                   CornerRadius="4"
                                                   Padding="6,2"
                                                   Margin="8,0,0,0"
                                                   Visibility="{Binding IsCombo, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="MEAL" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Price -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                  Text="{Binding Price}"
                                                  FontSize="15" FontWeight="Bold"
                                                  Foreground="{StaticResource McDonaldsYellow}"/>

                                        <!-- Modifiers -->
                                        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                                  Text="{Binding Modifiers}"
                                                  FontSize="12"
                                                  Foreground="#FFA726"
                                                  Visibility="{Binding HasModifiers, Converter={StaticResource BoolToVisibility}}"
                                                  Margin="0,4,0,0"/>

                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                                                   Orientation="Horizontal"
                                                   Margin="0,8,0,0">
                                            <!-- Quantity Controls -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Width="36" Height="36"
                                                   Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Minus" Width="20" Height="20"/>
                                            </Button>
                                            <Border Background="#404040" CornerRadius="4" Padding="12,4" Margin="4,0">
                                                <TextBlock Text="{Binding Quantity}"
                                                          FontSize="16" FontWeight="Bold"
                                                          Foreground="White"/>
                                            </Border>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Width="36" Height="36"
                                                   Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
                                            </Button>

                                            <!-- Modifiers Button -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Width="36" Height="36"
                                                   Margin="8,0,0,0"
                                                   Command="{Binding DataContext.OpenModifiersCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   Visibility="{Binding CanModify, Converter={StaticResource BoolToVisibility}}"
                                                   ToolTip="Modifiers">
                                                <materialDesign:PackIcon Kind="TuneVertical" Width="20" Height="20"/>
                                            </Button>

                                            <!-- Void Button -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Width="36" Height="36"
                                                   Foreground="{StaticResource McDonaldsRed}"
                                                   Command="{Binding DataContext.OpenVoidDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Void Item">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"/>
                                            </Button>

                                            <!-- Remove Button -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Width="36" Height="36"
                                                   Foreground="Gray"
                                                   Command="{Binding DataContext.RemoveOrderItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="Remove">
                                                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty Order Message -->
                <StackPanel Grid.Row="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="{Binding ItemCount, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}">
                    <materialDesign:PackIcon Kind="CartOutline"
                                            Width="64" Height="64"
                                            Foreground="Gray"
                                            HorizontalAlignment="Center"/>
                    <TextBlock Text="No items in order"
                              FontSize="16"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="Select items from the menu"
                              FontSize="12"
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Order Totals -->
                <Border Grid.Row="2" Background="#1A1A1A" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <TextBlock Text="Subtotal" FontSize="14" Foreground="Gray"/>
                            <TextBlock Text="{Binding Subtotal, Converter={StaticResource Currency}}"
                                      FontSize="14" Foreground="White"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Tax (8%)" FontSize="14" Foreground="Gray"/>
                            <TextBlock Text="{Binding Tax, Converter={StaticResource Currency}}"
                                      FontSize="14" Foreground="White"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Margin="0,8" Background="#404040"/>
                        <Grid>
                            <TextBlock Text="TOTAL" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Total, Converter={StaticResource Currency}}"
                                      FontSize="24" FontWeight="Bold"
                                      Foreground="{StaticResource McDonaldsYellow}"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                               Style="{StaticResource ActionButtonSecondary}"
                               Content="SEND TO KITCHEN"
                               Command="{Binding SendToKitchenCommand}"/>
                        <Button Grid.Column="1"
                               Style="{StaticResource ActionButtonPrimary}"
                               Content="PAY NOW"
                               Command="{Binding OpenPaymentCommand}"/>
                    </Grid>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="CLEAR ORDER"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           Height="40"
                           Margin="4,8,4,4"
                           Command="{Binding ClearOrderCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DIALOGS ========== -->

        <!-- Size Selection Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowSizeDialog, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="{StaticResource CardBackground}"
                                UniformCornerRadius="16"
                                Padding="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="400">
                <StackPanel>
                    <TextBlock Text="Select Size"
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>

                    <Button Style="{StaticResource LargeTouchButton}"
                           Content="SMALL"
                           Background="#4CAF50"
                           Command="{Binding SelectSizeCommand}"
                           CommandParameter="Small"/>
                    <Button Style="{StaticResource LargeTouchButton}"
                           Content="MEDIUM"
                           Background="{StaticResource McDonaldsYellow}"
                           Foreground="Black"
                           Command="{Binding SelectSizeCommand}"
                           CommandParameter="Medium"/>
                    <Button Style="{StaticResource LargeTouchButton}"
                           Content="LARGE"
                           Background="{StaticResource McDonaldsRed}"
                           Command="{Binding SelectSizeCommand}"
                           CommandParameter="Large"/>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="CANCEL"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           Height="48"
                           Margin="0,16,0,0"
                           Command="{Binding CancelSizeDialogCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>

        <!-- Combo Prompt Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowComboPrompt, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="{StaticResource CardBackground}"
                                UniformCornerRadius="16"
                                Padding="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="450">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Food"
                                            Width="64" Height="64"
                                            Foreground="{StaticResource McDonaldsYellow}"
                                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Make it a Meal?"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,8"/>
                    <TextBlock Text="Add Medium Fries + Medium Drink"
                              FontSize="16"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>

                    <Button Style="{StaticResource ActionButtonSecondary}"
                           Height="70"
                           FontSize="20"
                           Command="{Binding MakeItAMealCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" Width="28" Height="28" Margin="0,0,8,0"/>
                            <TextBlock Text="YES, MAKE IT A MEAL" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="NO THANKS"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           Height="50"
                           Margin="0,12,0,0"
                           Command="{Binding NoMealCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>

        <!-- Modifiers Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowModifierDialog, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="{StaticResource CardBackground}"
                                UniformCornerRadius="16"
                                Padding="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="500"
                                MaxHeight="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Customize Item"
                                  FontSize="24" FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ModifierTargetItem.DisplayName}"
                                  FontSize="16"
                                  Foreground="{StaticResource McDonaldsYellow}"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,16"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableModifiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="4"
                                           Height="56"
                                           HorizontalContentAlignment="Stretch"
                                           Background="{Binding IsSelected, Converter={StaticResource BoolToSelectionBrush}}"
                                           Command="{Binding DataContext.ToggleModifierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}">
                                        <Grid Margin="8,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Check"
                                                                        Width="24" Height="24"
                                                                        Foreground="White"
                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBlock Text="{Binding Name}"
                                                          FontSize="16"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PriceDisplay}"
                                                      FontSize="14" FontWeight="Bold"
                                                      Foreground="{StaticResource McDonaldsYellow}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                           Style="{StaticResource ActionButtonPrimary}"
                           Content="DONE"
                           Margin="0,16,0,0"
                           Command="{Binding CloseModifiersCommand}"/>
                </Grid>
            </materialDesign:Card>
        </Border>

        <!-- Void Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowVoidDialog, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="{StaticResource CardBackground}"
                                UniformCornerRadius="16"
                                Padding="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="400">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AlertCircle"
                                            Width="48" Height="48"
                                            Foreground="{StaticResource McDonaldsRed}"
                                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Void Item"
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,8"/>
                    <TextBlock Text="Manager PIN Required"
                              FontSize="14"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>

                    <!-- PIN Display -->
                    <Border Background="#1A1A1A"
                           CornerRadius="8"
                           Height="50"
                           Margin="0,0,0,16">
                        <TextBlock Text="{Binding VoidPin, Converter={StaticResource PinToMask}}"
                                  FontSize="28"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- PIN Pad -->
                    <UniformGrid Columns="3" Rows="4" HorizontalAlignment="Center">
                        <Button Content="1" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="1"/>
                        <Button Content="2" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="2"/>
                        <Button Content="3" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="3"/>
                        <Button Content="4" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="4"/>
                        <Button Content="5" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="5"/>
                        <Button Content="6" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="6"/>
                        <Button Content="7" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="7"/>
                        <Button Content="8" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="8"/>
                        <Button Content="9" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="9"/>
                        <Button Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding ClearVoidPinCommand}" Background="{StaticResource McDonaldsRed}">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                        <Button Content="0" Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding AppendVoidPinCommand}" CommandParameter="0"/>
                        <Button Style="{StaticResource PinPadButton}" Width="60" Height="60" Command="{Binding ConfirmVoidCommand}" Background="#4CAF50">
                            <materialDesign:PackIcon Kind="Check" Width="20" Height="20"/>
                        </Button>
                    </UniformGrid>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="CANCEL"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           Height="44"
                           Margin="0,16,0,0"
                           Command="{Binding CancelVoidCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>

        <!-- Payment Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowPaymentDialog, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="{StaticResource CardBackground}"
                                UniformCornerRadius="16"
                                Padding="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="500">
                <StackPanel>
                    <TextBlock Text="Payment"
                              FontSize="28" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>

                    <!-- Total Display -->
                    <Border Background="#1A1A1A" CornerRadius="12" Padding="24" Margin="0,16">
                        <StackPanel>
                            <TextBlock Text="Total Due" FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Total, Converter={StaticResource Currency}}"
                                      FontSize="48" FontWeight="Bold"
                                      Foreground="{StaticResource McDonaldsYellow}"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Payment Methods -->
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                               Style="{StaticResource ActionButtonSecondary}"
                               Height="80"
                               Command="{Binding PayCardCommand}">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CreditCard" Width="32" Height="32"/>
                                <TextBlock Text="CARD" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <materialDesign:Card Grid.Column="1"
                                            Background="#404040"
                                            UniformCornerRadius="8"
                                            Margin="4"
                                            Padding="8">
                            <StackPanel>
                                <TextBlock Text="CASH" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <!-- Amount Display -->
                                <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TenderedAmount, StringFormat=${0}}"
                                              FontSize="20" FontWeight="Bold"
                                              Foreground="White"
                                              HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Quick Amount Buttons -->
                                <UniformGrid Columns="2" Rows="2">
                                    <Button Content="$10" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="10"/>
                                    <Button Content="$20" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="20"/>
                                    <Button Content="$50" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="50"/>
                                    <Button Content="$100" Height="36" FontSize="12" Margin="2" Command="{Binding QuickTenderCommand}" CommandParameter="100"/>
                                </UniformGrid>

                                <!-- Change Display -->
                                <Border Background="#4CAF50" CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                       Visibility="{Binding ChangeAmount, Converter={StaticResource CountToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="Change" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ChangeAmount, Converter={StaticResource Currency}}"
                                                  FontSize="18" FontWeight="Bold"
                                                  Foreground="White"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button Style="{StaticResource ActionButtonPrimary}"
                                       Content="PAY CASH"
                                       Height="44"
                                       Margin="0,8,0,0"
                                       Command="{Binding PayCashCommand}"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="CANCEL"
                           Foreground="Gray"
                           BorderBrush="Gray"
                           Height="44"
                           Margin="0,16,0,0"
                           Command="{Binding CancelPaymentCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>

        <!-- Receipt Dialog -->
        <Border Grid.ColumnSpan="2"
               Background="#CC000000"
               Visibility="{Binding ShowReceiptDialog, Converter={StaticResource BoolToVisibility}}">
            <materialDesign:Card Background="White"
                                UniformCornerRadius="8"
                                Padding="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="350">
                <StackPanel>
                    <!-- Receipt Header -->
                    <TextBlock Text="McDonald's"
                              FontSize="28" FontWeight="Bold"
                              Foreground="Black"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Thank You For Your Order!"
                              FontSize="14"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              Margin="0,4,0,16"/>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <!-- Order Number -->
                    <Border Background="#FFC72C" CornerRadius="8" Padding="16" Margin="0,8">
                        <StackPanel>
                            <TextBlock Text="ORDER NUMBER"
                                      FontSize="12" FontWeight="Bold"
                                      Foreground="Black"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CompletedOrder.OrderNumber}"
                                      FontSize="48" FontWeight="Bold"
                                      Foreground="Black"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="LightGray" Margin="0,16,0,8"/>

                    <!-- Order Items -->
                    <ItemsControl ItemsSource="{Binding CompletedOrder.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="Black"/>
                                        <TextBlock Text="x" Margin="4,0" Foreground="Gray"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="Black"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding LineTotal, StringFormat=${0:F2}}"
                                              HorizontalAlignment="Right"
                                              Foreground="Black"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <!-- Totals -->
                    <Grid Margin="0,4">
                        <TextBlock Text="Subtotal" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.Subtotal, StringFormat=${0:F2}}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tax" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.TaxAmount, StringFormat=${0:F2}}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>
                    <Grid Margin="0,8">
                        <TextBlock Text="TOTAL" FontWeight="Bold" FontSize="18" Foreground="Black"/>
                        <TextBlock Text="{Binding CompletedOrder.Total, StringFormat=${0:F2}}"
                                  FontWeight="Bold" FontSize="18"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>

                    <Separator Background="LightGray" Margin="0,8"/>

                    <!-- Payment Info -->
                    <Grid Margin="0,4">
                        <TextBlock Text="Payment Method" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.PaymentMethod}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>
                    <Grid Margin="0,4" Visibility="{Binding CompletedOrder.ChangeGiven, Converter={StaticResource CountToVisibility}}">
                        <TextBlock Text="Change" Foreground="Gray"/>
                        <TextBlock Text="{Binding CompletedOrder.ChangeGiven, StringFormat=${0:F2}}"
                                  HorizontalAlignment="Right" Foreground="Black"/>
                    </Grid>

                    <Separator Background="LightGray" Margin="0,16,0,8"/>

                    <TextBlock Text="{Binding CompletedOrder.PaidAt, StringFormat={}{0:MM/dd/yyyy h:mm tt}}"
                              FontSize="12"
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>

                    <Button Style="{StaticResource ActionButtonSecondary}"
                           Content="NEW ORDER"
                           Foreground="Black"
                           Margin="0,16,0,0"
                           Command="{Binding CloseReceiptCommand}"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>
    </Grid>
</UserControl>
